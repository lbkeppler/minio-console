---
import type { Lang } from "../i18n/ui";
import { languages } from "../i18n/ui";
import { useTranslations, getLocalizedPath } from "../i18n/utils";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-lg">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
		<a href={getLocalizedPath(lang)} class="flex items-center gap-2">
			<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-400 to-brand-600 text-white shadow-lg shadow-brand-500/30">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7"></path>
					<path d="m21 7-9-4-9 4"></path>
					<path d="m3 7 9 4 9-4"></path>
					<path d="M12 11v8"></path>
				</svg>
			</div>
			<span class="text-lg font-semibold">MinIO Console</span>
		</a>

		<nav class="hidden items-center gap-8 md:flex">
			<a href="#features" class="text-sm text-slate-400 hover:text-slate-100">
				{t("nav.features")}
			</a>
			<a href="#download" class="text-sm text-slate-400 hover:text-slate-100">
				{t("nav.download")}
			</a>
			<a
				href="https://github.com/lbkeppler/minio-console"
				target="_blank"
				rel="noopener"
				class="text-sm text-slate-400 hover:text-slate-100"
			>
				{t("nav.github")}
			</a>
		</nav>

		<div class="flex items-center gap-3">
			<div class="flex items-center gap-1 rounded-lg border border-white/10 bg-white/5 p-1 text-xs">
				{Object.entries(languages).map(([code, _name]) => (
					<a
						href={getLocalizedPath(code as Lang)}
						class={`rounded-md px-2 py-1 uppercase transition-colors ${
							lang === code
								? "bg-brand-500 text-white"
								: "text-slate-400 hover:text-slate-100"
						}`}
					>
						{code}
					</a>
				))}
			</div>
		</div>
	</div>
</header>
